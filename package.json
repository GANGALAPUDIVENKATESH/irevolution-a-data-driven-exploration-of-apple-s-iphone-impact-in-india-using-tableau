{
  "name": "irevolution",
  "version": "1.0.0",
  "description": "A data-driven exploration of Apple's iPhone impact in India using Tableau",
  "main": "index.html",
  "scripts": {
    "start": "python3 -m http.server 8080",
    "analyze": "python3 scripts/data_analysis.py",
    "generate-charts": "python3 scripts/generate_static_charts.py",
    "validate-data": "python3 scripts/validate_datasets.py",
    "build": "echo 'Static project — no build required. Open index.html in browser.'"
  },
  "keywords": [
    "tableau",
    "data-visualization",
    "apple",
    "iphone",
    "india",
    "market-analysis",
    "dashboard"
  ],
  "author": "iRevolution Project",
  "license": "MIT",
  "dependencies": {
    "chart.js": "^4.4.0",
    "d3": "^7.8.5"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "python": ">=3.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/irevolution"
  }
}
